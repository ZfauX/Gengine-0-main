# ============================================
# Gengine Configuration Template
# Copy to .env and fill in all required values
# ============================================

# --- Server ---
PORT=8080
GIN_MODE=debug                # release|debug|test
BASE_URL=http://localhost:8080 # used for email links etc.
BACKUP_MAX_BACKUPS=10

# --- Database (REQUIRED) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=encounter
DB_PASSWORD=encounter
DB_NAME=encounter
DB_SSLMODE=disable

# --- Redis (optional) ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# !! SECURITY – CHANGE IMMEDIATELY !!
# ============================================

# JWT secret (REQUIRED) – generate with: openssl rand -base64 32
JWT_SECRET=&sxI},rE8'#<u96grssuY7)]^"w:!W<J
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Session secret (REQUIRED) – similarly strong and unique
SESSION_SECRET=0tMIzHo:IE3/|1s`A(>i{nSb_F_R=65<

# Admin credentials (REQUIRED) – email and strong password (min 12 chars)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=@U8\GA[/Y]yN$+rF2Aa*iFehz?}wg:V_

# ============================================
# External Services (enable by setting *_ENABLED=true)
# ============================================

# Google OAuth
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Yandex OAuth
YANDEX_ENABLED=false
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# reCAPTCHA
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# TLS (optional – leave empty for HTTP)
TLS_CERT_FILE=
TLS_KEY_FILE=