# ============================================
# Gengine Configuration Template
# Copy to .env and fill in all required values
# ============================================

# --- Server ---
PORT=8080
GIN_MODE=release               # release|debug|test
BASE_URL=http://localhost:8080 # used for email links and OAuth redirects
LOG_MAX_BACKUPS=10            # max number of log backups to keep

# --- Database (REQUIRED) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=encounter
# DB_PASSWORD – REQUIRED: set a strong password
DB_PASSWORD=
DB_NAME=encounter
DB_SSLMODE=require             # disable|require|verify-full

# --- Database Connection Pool (optional, defaults shown) ---
# DB_MAX_OPEN_CONNS=50        # max open connections (default: 50)
# DB_MAX_IDLE_CONNS=25        # max idle connections (default: 25)
# DB_CONN_MAX_LIFETIME=5m     # max connection lifetime (e.g. 5m, 1h)

# --- Redis (optional, Valkey-compatible) ---
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=

# ============================================
# !! SECURITY – CHANGE IMMEDIATELY !!
# ============================================

# JWT secret (REQUIRED) – generate with: openssl rand -base64 32
# JWT_SECRET – REQUIRED: set a strong random string
JWT_SECRET=

# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=168h

# Session secret (REQUIRED) – similarly strong and unique
# SESSION_SECRET – REQUIRED: set a strong random string
SESSION_SECRET=

# Admin credentials (REQUIRED) – email and strong password (min 12 chars)
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD – REQUIRED: set a strong password (min 12 chars)
ADMIN_PASSWORD=

# ============================================
# External Services (enable by setting *_ENABLED=true)
# ============================================

# Google OAuth
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET – required if enabled
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_ENABLED=false
GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET – required if enabled
GITHUB_CLIENT_SECRET=

# Yandex OAuth
YANDEX_ENABLED=false
YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET – required if enabled
YANDEX_CLIENT_SECRET=

# Stripe
STRIPE_ENABLED=false
# STRIPE_SECRET_KEY – required if enabled
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET – required if enabled
STRIPE_WEBHOOK_SECRET=

# SMTP (for email notifications and verification)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# SMTP_PASSWORD – required if enabled
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# reCAPTCHA (for form protection)
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY – required if enabled
RECAPTCHA_SECRET_KEY=

# TLS (optional – leave empty for HTTP)
TLS_CERT_FILE=
TLS_KEY_FILE=

# Sentry (optional – error tracking)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACING_RATE=0.1

# VAPID keys for Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=